{
  "name": "claude-rate-monitor",
  "version": "0.1.0",
  "description": "Floating desktop widget showing Anthropic API rate limits in real time",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^2.1.8"
  },
  "build": {
    "appId": "com.namchai.clauderatemonitor",
    "productName": "Claude Rate Monitor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
